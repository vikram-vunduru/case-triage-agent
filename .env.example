# ===== Anthropic =====
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ===== Demo modes =====
# Set to "mock" to use bundled sample data (works offline, recommended for demo).
# Set to "real" to use the real Salesforce / Confluence APIs.
SALESFORCE_MODE=mock
CONFLUENCE_MODE=mock

# ===== Salesforce (only used when SALESFORCE_MODE=real) =====
# Use a free Developer Edition org: https://developer.salesforce.com/signup
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=
SF_DOMAIN=login

# ===== Confluence (only used when CONFLUENCE_MODE=real) =====
CONFLUENCE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_USERNAME=
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=

# ===== Trust gate =====
# If Claude's confidence drops below this, we escalate instead of resolving.
CONFIDENCE_THRESHOLD=0.6

# Pause for human approval before write actions? (false = auto-execute, good for live demo flow)
REQUIRE_HUMAN_APPROVAL=false

# ===== Demo password (optional) =====
# When set, the UI requires entering this password before the Run pipeline button
# is usable. Leave empty to disable password protection entirely.
DEMO_PASSWORD=
DEMO_TOKEN_TTL_HOURS=24
